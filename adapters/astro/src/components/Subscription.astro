---
import type { SubscriptionData } from '@core/content/types'
const { data } = Astro.props as { data: SubscriptionData }
---

<section class="ui-section ui-section-odd">
  <section class="ui-section-container flow">
    <h2 class="ui-text-title-2">{data.title}</h2>
    <p>{data.text}</p>
    <form action="https://submit-form.com/EQhFyJAtN" method="post">
      <input type="email" name="email" placeholder="your@email.com" class="pa-xs" />
      <button class="ui-button pa-xs" type="submit"> Let me know how </button>
    </form>
  </section>
</section>

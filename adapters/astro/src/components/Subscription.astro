---
import type { StakeholderImpactData } from '@core/content/types'

const { data } = Astro.props as { data: StakeholderImpactData }
---

<section class="ui-section ui-section-odd">
  <section class="ui-section-container flow">
    <h2 class="ui-text-title-2">Integrate on your workflow</h2>
    <p>
      Generate name previews for your clients instantly. Once approved, the production vector is optimized and waiting
      for you.
    </p>
    <div class="">
      <input type="email" placeholder="your@email.com" class="pa-xs" />
      <button class="ui-button pa-xs"> Let me know how </button>
    </div>
  </section>
</section>

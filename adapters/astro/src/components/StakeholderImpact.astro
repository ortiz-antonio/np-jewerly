---
import type { StakeholderImpactData } from '@core/content/types'

const { data } = Astro.props as { data: StakeholderImpactData }
---

<section class="ui-section ui-section-odd">
  <section class="ui-section-container flow">
    <h2 class="ui-text-title-2">{data.title}</h2>
    {
      data.areas.map((area) => (
        <>
          <h3 class="ui-text-title-3">{area.title}</h3>
          <ul>
            {area.items.map((item) => (
              <li>{item}</li>
            ))}
          </ul>
        </>
      ))
    }
  </section>
</section>

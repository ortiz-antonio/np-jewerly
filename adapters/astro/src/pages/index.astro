---
import Hero from '../components/Hero.astro'
import landing from '@data/content/landing.json'

import Layout from '../layouts/Layout.astro'
import type { HeroData, StakeholderImpactData } from '@core/content/types'
import Subscription from 'src/components/Subscription.astro'

const { hero, impact } = landing as { hero: HeroData; impact: StakeholderImpactData }
---

<Layout>
  <Hero data={hero} />
  <Subscription data={impact} />
</Layout>

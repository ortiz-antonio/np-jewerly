---
import Hero from '../components/Hero.astro'
import landing from '@data/content/landing.json'

import Layout from '../layouts/Layout.astro'
import type { HeroData, SubscriptionData } from '@core/content/types'
import Subscription from 'src/components/Subscription.astro'

const { hero, subscription } = landing as { hero: HeroData; subscription: SubscriptionData }
---

<Layout>
  <Hero data={hero} />
  <Subscription data={subscription} />
</Layout>

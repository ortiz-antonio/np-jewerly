---
import Hero from '../components/Hero.astro'
import landing from '@data/content/landing.json'

import Layout from '../layouts/Layout.astro'
import type { HeroData } from '@core/content/types'
import Subscription from 'src/components/Subscription.astro'

const { hero } = landing as { hero: HeroData }
---

<Layout>
  <Hero data={hero} />
  <Subscription />
</Layout>
